Table supplier {
  id int [pk, increment]
  name varchar(255) [not null]
  contact_person varchar(150)
  email varchar(254)
  phone varchar(30)
  address text
  is_active boolean [default: true]
  created_at timestamp
}

Table warehouse {
  id int [pk, increment]
  name varchar(255) [not null]
  address text
  is_active boolean [default: true]
}

Table product {
  id int [pk, increment]
  name varchar(255) [not null]
  type varchar(20)
  sku varchar(64) [unique]
  brand varchar(100)
  description text
  price decimal(10,2) [not null]
  quantity int [default: 0]
  reorder_level int [default: 0]
  supplier_id int
  is_active boolean [default: true]
  last_modified_by_username varchar(150)
  created_at timestamp
  updated_at timestamp
}

Table ac_product {
  id int [pk, increment]
  product_id int [unique]
  tonnage decimal(4,1) [not null]
  star_rating int [default: 3]
  energy_label varchar(10)
  refrigerant_type varchar(20)
}

Table stock_location {
  id int [pk, increment]
  warehouse_id int [not null]
  product_id int [not null]
  bin_code varchar(50)
  quantity int [default: 0]

  Indexes {
    (warehouse_id, product_id, bin_code) [unique]
  }
}

Table stock_transaction {
  id int [pk, increment]
  product_id int [not null]
  warehouse_id int [not null]
  txn_type varchar(20) [not null]
  quantity_change int [not null]
  reference varchar(100)
  performed_by varchar(150)
  created_at timestamp
}

Table purchase_order {
  id int [pk, increment]
  po_number varchar(50) [unique, not null]
  supplier_id int [not null]
  warehouse_id int [not null]
  status varchar(20) [default: 'DRAFT']
  expected_date date
  received_date date
  notes text
  created_by varchar(150)
  created_at timestamp
  updated_at timestamp
}

Table po_line_item {
  id int [pk, increment]
  purchase_order_id int [not null]
  product_id int [not null]
  quantity_ordered int [not null]
  quantity_received int [default: 0]
  unit_price decimal(10,2) [not null]

  Indexes {
    (purchase_order_id, product_id) [unique]
  }
}

Table sales_order {
  id int [pk, increment]
  so_number varchar(50) [unique, not null]
  customer_name varchar(255) [not null]
  customer_phone varchar(30)
  warehouse_id int [not null]
  status varchar(20) [default: 'PENDING']
  order_date date
  notes text
  created_by varchar(150)
  created_at timestamp
  updated_at timestamp
}

Table so_line_item {
  id int [pk, increment]
  sales_order_id int [not null]
  product_id int [not null]
  quantity int [not null]
  unit_price decimal(10,2) [not null]

  Indexes {
    (sales_order_id, product_id) [unique]
  }
}

Ref: product.supplier_id > supplier.id
Ref: ac_product.product_id > product.id
Ref: stock_location.warehouse_id > warehouse.id
Ref: stock_location.product_id > product.id
Ref: stock_transaction.product_id > product.id
Ref: stock_transaction.warehouse_id > warehouse.id
Ref: purchase_order.supplier_id > supplier.id
Ref: purchase_order.warehouse_id > warehouse.id
Ref: po_line_item.purchase_order_id > purchase_order.id
Ref: po_line_item.product_id > product.id
Ref: sales_order.warehouse_id > warehouse.id
Ref: so_line_item.sales_order_id > sales_order.id
Ref: so_line_item.product_id > product.id



Table customer {
  id int [pk, increment]
  name varchar(255) [not null]
  phone varchar(20) [not null]
  email varchar(254)
  address text
  created_at timestamp
}

Table invoice {
  id int [pk, increment]
  customer_id int [not null]
  invoice_number varchar(50) [unique, not null]
  date timestamp
  total_amount decimal(10,2) [default: 0]
  paid_amount decimal(10,2) [default: 0]
  status varchar(20) [default: 'PENDING', note: 'PENDING | PAID | PARTIAL']
}

Table invoice_item {
  id int [pk, increment]
  invoice_id int [not null]
  product_id int [not null]
  quantity int [not null]
  price decimal(10,2) [not null]
  total decimal(10,2) [not null]
}

Ref: invoice.customer_id > customer.id
Ref: invoice_item.invoice_id > invoice.id
Ref: invoice_item.product_id > product.id